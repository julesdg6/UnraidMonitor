# Runtime Environment Variables
# Copy this file to config/.env and fill in your values
#
# For build-time variables (DOCKER_GID), see .env.example in project root

# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789

# Optional - AI features (configure at least one for /diagnose, NL chat, smart ignore)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_HOST=http://localhost:11434

# Optional - override the default AI model (e.g. qwen2.5:7b, claude-haiku-4-5-20251001, gpt-4o)
# If unset, uses the built-in default for the configured provider.
DEFAULT_MODEL=

# Optional - enables Unraid server monitoring (CPU, memory, array, UPS)
UNRAID_API_KEY=your_unraid_api_key_here
