# Docker Compose Build Variables
# Copy this file to .env and adjust values for your system
#
# This file is for BUILD-TIME variables only.
# Runtime secrets (API keys, tokens) go in config/.env

# Docker socket group ID - required for non-root container access
# Find your system's docker GID with: ls -ln /var/run/docker.sock
# Look at the group number (4th column), commonly 281 on Unraid, 999 on Ubuntu
DOCKER_GID=281
